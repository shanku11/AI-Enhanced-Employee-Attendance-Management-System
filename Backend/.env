# Server Configuration
PORT=5000
ENVIRONMENT=development

# Database Configuration
# - For out-of-the-box local operation, leaves this default file-based SQLite database url:
DATABASE_URL=sqlite:///./attendance.db
# - For enterprise PostgreSQL connection, uncomment and configure the line below:
# DATABASE_URL=postgresql://db_user:db_password@localhost:5432/attendance_db

# Generative AI Configuration
# Paste your Google Gemini API Key here to unlock real-time Gemini AI attendance analytics!
# If left empty, the system automatically uses our built-in realistic HR Insight Generator.
GEMINI_API_KEY=

# WebSocket Configuration
WEBSOCKET_ENABLED=true
WEBSOCKET_PING_INTERVAL=30

# ML Model Configuration
ML_MODEL_PATH=./ML/attendance_model.joblib
ENSEMBLE_MODEL_PATH=./ML/ensemble_model.joblib
ML_CONFIDENCE_THRESHOLD=0.65
PREDICTION_CACHE_DURATION_HOURS=24

# Security Configuration
ENABLE_CORS=true
CORS_ORIGINS=*

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

